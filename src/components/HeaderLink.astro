---
export interface Props extends astroHTML.JSX.AnchorHTMLAttributes {}
const { href, class: className, ...props } = Astro.props
const pathname = Astro.url.pathname.replace(/\/+$/, '') || '/'
const target = String(href).replace(/\/+$/, '') || '/'
const isActive = pathname === target
---

<a
  href={href}
  class:list={['header-link', isActive && 'header-link--active', className]}
  aria-current={isActive ? 'page' : undefined}
  {...props}
>
  <slot />
</a>

<style is:global>
  .header-link {
    align-items: center;
    color: var(--everforest-text-secondary);
    display: inline-flex;
    font-size: 0.9375rem;
    font-weight: 500;
    gap: 0.35rem;
    letter-spacing: 0;
    line-height: 1.2;
    text-decoration: none;
    transition: color 0.18s ease;
  }

  .header-link:hover,
  .header-link:focus-visible {
    color: var(--everforest-text-primary);
  }

  .header-link--active {
    color: var(--everforest-text-primary);
    text-decoration: underline;
    text-decoration-color: var(--everforest-link-accent);
    text-decoration-thickness: 2px;
    text-underline-offset: 6px;
  }

  .header-link:focus-visible {
    border-radius: 4px;
    outline: 2px solid var(--everforest-focus-ring);
    outline-offset: 4px;
  }
</style>
