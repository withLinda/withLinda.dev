---
export interface Props {
  className?: string
}
const { className = '' } = Astro.props
---

<main class={`page-content ${className}`}>
  <slot />
</main>

<style is:global>
  .page-content {
    padding-top: calc(var(--header-h, 72px) + var(--space-lg));
    padding-inline: var(--page-gutter);
    margin-inline: auto;
    max-width: var(--page-measure);
  }
</style>
