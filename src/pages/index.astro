---
import { getCollection } from 'astro:content'
import BaseHead from '../components/BaseHead.astro'
import Header from '../components/Header.astro'
import Footer from '../components/Footer.astro'
import Body from '../components/Body.astro'
import Content from '../components/Content.astro'
import {
  SITE_TITLE,
  SITE_DESCRIPTION,
  SITE_TAGLINE,
  CATEGORY_NAMES,
  CATEGORY_TAGS,
} from '../config'

const dateFmt = new Intl.DateTimeFormat('en-US', {
  year: 'numeric',
  month: 'short',
  day: 'numeric',
})

const posts = await getCollection('blog')

const decorated = posts
  .map((post) => {
    const categoryDir = post.id.includes('/') ? post.id.split('/')[0] : ''
    return {
      url: `/blog/${post.id}`,
      title: post.data.title,
      description: post.data.description,
      date: dateFmt.format(new Date(post.data.pubDate)),
      pubDate: new Date(post.data.pubDate),
      categoryTag: CATEGORY_TAGS[categoryDir] ?? categoryDir,
      categoryName: CATEGORY_NAMES[categoryDir] ?? categoryDir,
    }
  })
  .sort((a, b) => b.pubDate.getTime() - a.pubDate.getTime())

const [hero, ...rest] = decorated
---

<!doctype html>
<html lang="en" class="no-flash">
  <head>
    <BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
  </head>
  <Body>
    <Header />
    <Content>
      <section class="intro">
        <p class="intro-tagline">{SITE_TAGLINE}</p>
      </section>

      {
        hero && (
          <article class="hero">
            <p class="hero-eyebrow">
              <span>Latest</span>
              <span class="hero-eyebrow__sep">·</span>
              <time datetime={hero.pubDate.toISOString()}>{hero.date}</time>
              <span class="hero-eyebrow__sep">·</span>
              <span class="chip" title={hero.categoryName}>{hero.categoryTag}</span>
            </p>
            <h2 class="hero-title">
              <a href={hero.url}>{hero.title}</a>
            </h2>
            <p class="hero-desc">{hero.description}</p>
            <a class="hero-cta" href={hero.url} aria-label={`Read: ${hero.title}`}>
              Read post
            </a>
          </article>
        )
      }

      {
        rest.length > 0 && (
          <section class="archive">
            <h2 class="archive-label">More posts</h2>
            <ol class="post-list">
              {rest.map((post) => (
                <li class="post-row">
                  <a class="post-row__link" href={post.url}>
                    <p class="post-row__meta">
                      <time datetime={post.pubDate.toISOString()}>{post.date}</time>
                      <span class="post-row__meta__sep">·</span>
                      <span class="chip" title={post.categoryName}>{post.categoryTag}</span>
                    </p>
                    <h3 class="post-row__title">{post.title}</h3>
                  </a>
                </li>
              ))}
            </ol>
          </section>
        )
      }
    </Content>
    <Footer />
  </Body>
</html>
