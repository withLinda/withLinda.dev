---
import { getCollection } from 'astro:content'
import BaseHead from '../components/BaseHead.astro'
import Header from '../components/Header.astro'
import Footer from '../components/Footer.astro'
import Body from '../components/Body.astro'
import Content from '../components/Content.astro'
import {
  SITE_TITLE,
  SITE_DESCRIPTION,
  SITE_TAGLINE,
  CATEGORY_NAMES,
} from '../config'

const dateFmt = new Intl.DateTimeFormat('en-US', {
  year: 'numeric',
  month: 'short',
  day: 'numeric',
})

const posts = await getCollection('blog')

type PostRow = {
  url: string
  title: string
  date: string
  pubDate: Date
}

type CategoryGroup = {
  key: string
  name: string
  posts: PostRow[]
}

const formatCategoryFallback = (categoryDir: string) =>
  categoryDir
    .split('-')
    .map((word) => word.charAt(0).toUpperCase() + word.slice(1))
    .join(' ')

const sortedPosts = posts
  .map((post) => ({
    post,
    pubDate: new Date(post.data.pubDate),
  }))
  .sort((a, b) => b.pubDate.getTime() - a.pubDate.getTime())

const categoryGroups = sortedPosts.reduce<CategoryGroup[]>((groups, { post, pubDate }) => {
  const categoryDir = post.id.split('/')[0] || 'uncategorized'
  const categoryName =
    CATEGORY_NAMES[categoryDir] ??
    (categoryDir === 'uncategorized'
      ? 'Uncategorized'
      : formatCategoryFallback(categoryDir))

  let group = groups.find((item) => item.key === categoryDir)
  if (!group) {
    group = {
      key: categoryDir,
      name: categoryName,
      posts: [],
    }
    groups.push(group)
  }

  group.posts.push({
    url: `/blog/${post.id}`,
    title: post.data.title,
    date: dateFmt.format(pubDate),
    pubDate,
  })

  return groups
}, [])
---

<!doctype html>
<html lang="en" class="no-flash">
  <head>
    <BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
  </head>
  <Body>
    <Header />
    <Content>
      <section class="intro">
        <p class="intro-tagline">{SITE_TAGLINE}</p>
      </section>

      {
        categoryGroups.map((category) => (
          <section class="category-section" aria-labelledby={`category-${category.key}`}>
            <h2 class="category-heading" id={`category-${category.key}`}>
              {category.name}
            </h2>
            <ol class="post-list">
              {category.posts.map((post) => (
                <li class="post-row">
                  <a class="post-row__link" href={post.url}>
                    <p class="post-row__meta">
                      <time datetime={post.pubDate.toISOString()}>{post.date}</time>
                    </p>
                    <h3 class="post-row__title">{post.title}</h3>
                  </a>
                </li>
              ))}
            </ol>
          </section>
        ))
      }
    </Content>
    <Footer />
  </Body>
</html>
